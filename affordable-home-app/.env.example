# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role secret — required ONLY for scripts/ingest.ts, run locally.
# Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# SendGrid — required for /api/send-results to send email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# PostHog analytics
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=
